# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# STRIPE_SECRET_KEY: enables real Stripe Checkout for Pro/Founder plans.
# Without it, "Go Pro" runs in demo mode (unlocks Pro locally). Use a test key (sk_test_...).
STRIPE_SECRET_KEY=""

# GEMINI_MODEL: optional model override (default gemini-2.5-flash).
GEMINI_MODEL=""

# --- Growth engine (free tier: Discord + Bluesky) ---
# MARKET_API: where the FastAPI market backend runs (signal source for drafts).
MARKET_API="http://localhost:8000"
# VITE_MARKET_QUERIES: comma-separated event universes the TERMINAL covers (build-time).
VITE_MARKET_QUERIES="World Cup,NFL"
# GROWTH_QUERIES: comma-separated events the autonomous GROWTH engine drafts signals from.
GROWTH_QUERIES="World Cup,NFL"

# --- Auth (optional): Google sign-in + per-user watchlist sync. See docs/AUTH.md. ---
# Without these, the app runs in local mode (watchlist stays on-device, no sign-in UI).
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
# DISCORD_WEBHOOK_URL: a channel webhook URL → free auto-posting, no approval. Leave blank to dry-run.
DISCORD_WEBHOOK_URL=""
# BLUESKY: handle + app password (bsky.app → Settings → App Passwords). Leave blank to dry-run.
BLUESKY_HANDLE=""
BLUESKY_APP_PASSWORD=""
# BUFFER (free tier): one integration reaches X / Instagram / LinkedIn / Threads / etc. via
# Buffer's official-partner credentials — no per-platform review. Get a key at
# publish.buffer.com/settings/api. Free tier = 1 key, 100 req/24h, 3,000 req/30d (plenty for
# approval-gated posting). BUFFER_CHANNEL_IDS = comma-separated channel IDs to publish to.
BUFFER_ACCESS_TOKEN=""
BUFFER_CHANNEL_IDS=""
# GROWTH_AUTODRAFT: "1" to auto-draft on an in-process cadence (free, local; no external scheduler).
GROWTH_AUTODRAFT=""
GROWTH_AUTODRAFT_HOURS="6"
# GROWTH_CRON_SECRET: shared secret that guards POST /api/growth/cron so an external scheduler
# (Google Cloud Scheduler — 3 free jobs/mo) can trigger drafting. See docs/CLOUD_SCHEDULER.md.
GROWTH_CRON_SECRET=""
# GROWTH_NOTIFY_WEBHOOK: a Discord webhook that pings you when new drafts await approval.
GROWTH_NOTIFY_WEBHOOK=""
# GROWTH_STORE: where the approval queue lives — "firestore" (durable) or "file" (local dev).
# Defaults to firestore when a GCP project is detected (e.g. on Cloud Run), else file.
GROWTH_STORE=""
# GROWTH_COLLECTION: Firestore collection name (default "growth_drafts").
GROWTH_COLLECTION=""
# FIRESTORE_PROJECT_ID: only needed to force a project id outside Cloud Run.
FIRESTORE_PROJECT_ID=""

# --- Media pipeline (optional; attaches real captures of the live app to Buffer posts) ---
# GROWTH_MEDIA: "" (off) | "screenshot" | "recording" — what to capture and attach to X/LinkedIn.
GROWTH_MEDIA=""
# GROWTH_MEDIA_BUCKET: public GCS bucket that hosts the media (Buffer needs a URL, not an upload).
GROWTH_MEDIA_BUCKET=""
# GROWTH_MEDIA_URL: page to capture (defaults to APP_URL — i.e. our own live terminal).
GROWTH_MEDIA_URL=""
# GROWTH_MEDIA_SECONDS: recording length in seconds (default 6).
GROWTH_MEDIA_SECONDS=""
# GROWTH_VIDEO_MODEL: AI video model id (Veo / "omni" / etc.) for the gated generateAiVideo hook.
GROWTH_VIDEO_MODEL=""
# GROWTH_MEDIA_AUDIO: path to a licensed music track to mix into recordings. If absent, a soft
# royalty-free ambient bed is synthesized. (Do NOT commit copyrighted audio to the repo.)
GROWTH_MEDIA_AUDIO=""
# GROWTH_BRAND_FONT: font used for the video watermark (default bundled JetBrains Mono).
GROWTH_BRAND_FONT=""
